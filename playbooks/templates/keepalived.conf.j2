vrrp_script chk_haproxy {
    script "killall -0 haproxy"
    interval 2
    weight 50
}

vrrp_instance VI_1 {
    state {{ (inventory_hostname == 'HAProxyOne_VM') | ternary('MASTER', 'BACKUP') }}
    interface enp1s0
    virtual_router_id 51
    priority {{ (inventory_hostname == 'HAProxyOne_VM') | ternary('150', '100') }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass 123456
    }

    virtual_ipaddress {
        192.168.222.200/24 dev enp1s0
    }

    track_script {
        chk_haproxy
    }
}